# Root-level gitignore
# Covers both frontend (convonest/) and backend (secure-chat-backend/)

# Dependencies
node_modules/
**/node_modules/

# Environment variables - NEVER commit these
.env
**/.env
.env.local
.env.production

# Build outputs
dist/
dist-ssr/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Vercel
.vercel/
